# Server Configuration
NODE_ENV=development
# In production/containers bind all interfaces (0.0.0.0). Defaults to that
# automatically when NODE_ENV=production if HOST is unset.
HOST=localhost
PORT=8080

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/go-game
MONGODB_DB_NAME=go-game

# JWT Configuration (required in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=30d

# PartyKit webhook secret (required in production). Must match the value the
# PartyKit server sends as the x-webhook-secret header.
PARTYKIT_WEBHOOK_SECRET=your-partykit-webhook-secret-change-this-in-production

# CORS Configuration (required in production).
# Comma-separated list of allowed web origins, e.g.:
#   CORS_ORIGIN=https://your-user.github.io,https://app.example.com
# Capacitor/native origins (capacitor://localhost, http(s)://localhost) are
# allowed automatically by the API and do NOT need to be listed here.
CORS_ORIGIN=http://localhost:4200

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
# Stricter cap for /api/auth/login and /api/auth/register (brute-force defense)
AUTH_RATE_LIMIT_MAX_REQUESTS=10

# Logging
LOG_LEVEL=debug